# WeatherQ Environment Variables
# Copy this file to .env and fill in your values

# ─────────────────────────────────────────────
# WEATHER API (Open-Meteo is FREE — no key needed)
# Open-Meteo: https://open-meteo.com
# No API key required for Open-Meteo.
# ─────────────────────────────────────────────

# OPTIONAL: OpenWeatherMap key (only if you switch to OWM instead of Open-Meteo)
# Get it free at: https://openweathermap.org/api
# EXPO_PUBLIC_OWM_API_KEY=your_openweathermap_key_here

# ─────────────────────────────────────────────
# QUOTES API (ZenQuotes is FREE — no key needed)
# ZenQuotes: https://zenquotes.io
# No API key required.
# ─────────────────────────────────────────────

# OPTIONAL: API Ninjas key (alternative quotes API)
# Get it free at: https://api-ninjas.com
# EXPO_PUBLIC_API_NINJAS_KEY=your_api_ninjas_key_here

# ─────────────────────────────────────────────
# MONETIZATION — AdMob production unit IDs
# ─────────────────────────────────────────────
# In development (__DEV__) the app uses Google's test ad units, so you
# don't need any of these to test. Fill them in only when you're ready
# to publish — the AdService picks them up automatically in production.
#
# App IDs go in app.json under react-native-google-mobile-ads plugin.
# Get them from https://apps.admob.com → Apps → App settings.

# Interstitial (shown after every 3rd share/download, max once per 6h)
# EXPO_PUBLIC_ADMOB_ANDROID_INTERSTITIAL_ID=ca-app-pub-xxxxxxxxxxxxxxxx/xxxxxxxxxx
# EXPO_PUBLIC_ADMOB_IOS_INTERSTITIAL_ID=ca-app-pub-xxxxxxxxxxxxxxxx/xxxxxxxxxx

# Banner (not used yet — reserved for future placement)
# EXPO_PUBLIC_ADMOB_ANDROID_BANNER_ID=ca-app-pub-xxxxxxxxxxxxxxxx/xxxxxxxxxx
# EXPO_PUBLIC_ADMOB_IOS_BANNER_ID=ca-app-pub-xxxxxxxxxxxxxxxx/xxxxxxxxxx

# Rewarded (reserved for premium share-card themes)
# EXPO_PUBLIC_ADMOB_ANDROID_REWARDED_ID=ca-app-pub-xxxxxxxxxxxxxxxx/xxxxxxxxxx
# EXPO_PUBLIC_ADMOB_IOS_REWARDED_ID=ca-app-pub-xxxxxxxxxxxxxxxx/xxxxxxxxxx
